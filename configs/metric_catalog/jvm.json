{
  "domain": "jvm",
  "items": [
    {
      "id": "jvm_heap_usage",
      "name": "JVM Heap Usage",
      "description": "JVM heap used percentage.",
      "current_promql": "sum by(job, instance) (jvm_memory_used_bytes{area=\"heap\"}) / sum by(job, instance) (jvm_memory_max_bytes{area=\"heap\"}) * 100",
      "range_promql": "sum by(job, instance) (jvm_memory_used_bytes{area=\"heap\"}) / sum by(job, instance) (jvm_memory_max_bytes{area=\"heap\"}) * 100",
      "value_type": "percent",
      "unit": "%",
      "analysis_type": "jvm_memory",
      "direction": "higher_is_bad",
      "warning": 75,
      "critical": 90,
      "labels_to_keep": ["job", "instance"]
    },
    {
      "id": "jvm_gc_pause_rate",
      "name": "JVM GC Pause Rate",
      "description": "Seconds spent in GC pause per second.",
      "current_promql": "sum by(job, instance) (rate(jvm_gc_pause_seconds_sum[5m]))",
      "range_promql": "sum by(job, instance) (rate(jvm_gc_pause_seconds_sum[5m]))",
      "value_type": "number",
      "unit": "s/s",
      "analysis_type": "jvm_gc",
      "direction": "higher_is_bad",
      "warning": 0.05,
      "critical": 0.2,
      "labels_to_keep": ["job", "instance"]
    },
    {
      "id": "jvm_threads_live",
      "name": "JVM Live Threads",
      "description": "Current JVM live thread count.",
      "current_promql": "jvm_threads_live_threads",
      "range_promql": "jvm_threads_live_threads",
      "value_type": "number",
      "unit": "",
      "analysis_type": "threshold_trend",
      "direction": "higher_is_bad",
      "warning": 500,
      "critical": 1000,
      "labels_to_keep": ["job", "instance"]
    }
  ]
}
